{
  "rewrites": [
    { "source": "/api/properties", "destination": "/api/properties" },
    { "source": "/api/enquiries",  "destination": "/api/properties" },
    { "source": "/api/leads",      "destination": "/api/properties" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "ignoreCommand": "git diff --name-only HEAD^ HEAD | grep -qvE '\\.(html|css|json|md|txt|png|jpg|jpeg|gif|svg|ico)$'"
}
